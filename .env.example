### AutoCallAI environment template
### Copy this file to .env and fill values.

# API keys
ELEVENLABS_API_KEY=
GEMINI_API_KEY=

# Core model/runtime settings
GEMINI_MODEL=gemini-2.0-flash
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=30
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_SECONDS=1
PROMPT_TOKEN_BUDGET=500

# ElevenLabs agent settings
ELEVENLABS_AGENT_ID=
ELEVENLABS_AGENT_NAME=AutoCallAI - Greenfield Medical
ELEVENLABS_VOICE_ID=
ELEVENLABS_FIRST_MESSAGE=Hi there, this is Sarah from Greenfield Medical Practice. How can I help you today?

# Webhook URLs
N8N_CALL_HANDLER_WEBHOOK_URL=
N8N_ANALYSIS_WEBHOOK_URL=

# Optional local web config
WEB_AGENT_ID=
